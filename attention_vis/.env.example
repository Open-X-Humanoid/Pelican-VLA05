# attnvis environment overrides.
# Copy to .env when the defaults in src/attnvis/config.py don't match your machine.
#
#   cp .env.example .env
#   set -a && source .env && set +a
#   pip install -e .
#   python -m attnvis run --scenes robotwin:adjust_bottle:0 --nframes 3

# --- Output root (default: <repo>/outputs) -------------------------------
# ATTNVIS_OUT=/data/attnvis_out

# --- Dataset roots -------------------------------------------------------
# ATTNVIS_LIBERO_ROOT=/path/to/libero
# ATTNVIS_ROBOTWIN_ROOT=/path/to/robotwin
# LeRobot 3.0 collections (see README §④); leave unset to disable the
# tienkung / ur5e* / agilex_jd / realsource_v30 / franka_fr3 sources.
# ATTNVIS_UNIFY_ROOT=/path/to/unify/ur_data_lerobot         # tienkung / ur5e
# ATTNVIS_LEROBOT_V3_ROOT=/path/to/unify/lerobot_data_v3    # ur5e_v3 / ur5e_dual / franka_fr3
# ATTNVIS_VLA_LEROBOT_ROOT=/path/to/datasets/vla_lerobot    # agilex_jd / realsource_world_v30

# --- PelicanVLA (the reference adapter shipped with attnvis) -------------
# ATTNVIS_PELICANVLA_SRC=/path/to/pelicanvla_release
# ATTNVIS_PELICANVLA_CKPT=/path/to/pelicanvla_checkpoint
# ATTNVIS_PELICANVLA_PY=/path/to/venv/bin/python   # optional; default = current interpreter
# QWEN3_VL_PATH=/path/to/Qwen3-VL-4B-Instruct
# COSMOS_TOKENIZER_PATH=/path/to/Cosmos-Tokenizer-CI8x8

# --- Behavior flags ------------------------------------------------------
# PELICANVLA_CAPTURE=auto     # auto | twohop | direct
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
